<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	<TargetFramework>net10.0</TargetFramework>
	<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
	<PackageId>ColoredLogger</PackageId>
	<Version>1.0.0</Version>
	<Authors>Hamza Zafar</Authors>
	<Company>Hamza</Company>
	<Description>A lightweight, colored logging library for clean terminal output.</Description>
	<PackageTags>console;logging;terminal;ui;styles</PackageTags>
	<PackageLicenseExpression>MIT</PackageLicenseExpression>
	<RepositoryUrl>https://github.com/HamzaCodeBase/ConsoleDrama</RepositoryUrl>
  </PropertyGroup>

</Project>
